{
    "name": "yellowrobot/craft-dispatch",
    "description": "Dispatch - template management and event-driven sending for Craft CMS",
    "type": "craft-plugin",
    "license": "proprietary",
    "keywords": [
        "craft",
        "cms",
        "craftcms",
        "email",
        "templates",
        "transactional"
    ],
    "authors": [
        {
            "name": "Yellow Robot Studios",
            "homepage": "https://yellowrobotstudios.com"
        }
    ],
    "support": {
        "issues": "https://github.com/yellowrobotstudios/craft-dispatch/issues",
        "source": "https://github.com/yellowrobotstudios/craft-dispatch"
    },
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^5.0"
    },
    "require-dev": {
        "craftcms/ecs": "dev-main",
        "craftcms/phpstan": "dev-main",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "yellowrobot\\craftdispatch\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "yellowrobot\\craftdispatch\\tests\\": "tests/"
        }
    },
    "extra": {
        "handle": "craft-dispatch",
        "name": "Dispatch",
        "developer": "Yellow Robot Studios",
        "developerUrl": "https://yellowrobotstudios.com",
        "class": "yellowrobot\\craftdispatch\\CraftDispatch"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true
        }
    }
}
